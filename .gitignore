# Dependencies
node_modules/

# Build output
dist/

# Environment files
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
.cursor/
# .claude/ — selectively ignored. We commit project subagents (.claude/agents/*.md)
# but exclude user-specific settings and the local cache.
.claude/settings.local.json
.claude/cache/
.claude/skills/
*.code-workspace

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*

# Test coverage
coverage/

# Temporary files
tmp/
temp/
.scan-issues.json
.jules-last-issues.json
retro-*.txt

# Maestro AI
.agent/

# Scan results (stored daily) — exclude contents but not the directory itself, so the
# exception below can re-include monitor-list.json (parent-dir exclusions block re-include).
results/*
# Exception: monitor-list.json IS committed daily so follow-up state survives CI runs.
!results/monitor-list.json
# Exception: ticker-outcomes.json drives TD-21 (auto blacklist) + TD-23 (hot streak)
# at scan time. Refreshed weekly by .github/workflows/weekly-stats-refresh.yml.
!results/ticker-outcomes.json
# Exception: sector-outcomes.json drives TD-15 (dynamic sector blacklist).
# Same weekly refresh cadence as ticker-outcomes.
!results/sector-outcomes.json
# Finnhub fundamentals cache (TTL 7d) — never committed, never shared across machines.
results/finnhub-cache/
.claude/worktrees/
.fuse_hidden*
