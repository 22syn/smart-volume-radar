# Smart Volume Radar - Environment Template
# Copy to .env and fill in your values. Never commit .env.

# === REQUIRED ===
FINNHUB_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GOOGLE_SHEET_ID=

# === Optional: Twelve Data (RSI/SMA fetch, Yahoo fallback) ===
# TWELVE_DATA_API_KEY=

# === Optional: LLM Summary ===
# ENABLE_LLM_SUMMARY=true
# LLM_PROVIDER=openai  (or groq, perplexity, gemini)
# LLM_MODEL= (optional; defaults: gpt-4o-mini / sonar / gemini-2.0-flash / llama-3.3-70b-versatile)
# LLM_SIGNALS_ONLY=false (if true, only topSignals analyzed; else include silent-activity setups)
# LLM_MIN_RVOL=2
# LLM_PER_STOCK=true (per-stock mode; false=1 batch call, recommended for Gemini free tier ~10–15 RPM)
# OPENAI_API_KEY=
# PERPLEXITY_API_KEY=
# GEMINI_API_KEY=  (free tier: ~10–15 RPM; use LLM_PER_STOCK=false or switch provider if 429)
# GROQ_API_KEY=  (LLM + ticker classification for indices; free tier: console.groq.com/keys)
# ENABLE_LLM_WEEKLY_SUMMARY=true  (weekly evaluation on Sundays; uses same provider/keys)

# === Optional: Override defaults ===
# MIN_RVOL=2.0
# TOP_N=999 (default: show all signals; no limit)
# PRICE_CHANGE_THRESHOLD=2
# USE_FETCHED_INDICATORS=true

# === Debug / CI ===
# FORCE_SCAN=true
# DEBUG=false
